# ────────────────────────────────────────────────────────
# Supabase Local Development Environment Variables
# ────────────────────────────────────────────────────────
# These values are generated when you run `supabase start`
# Copy this file to `.env` and fill in the values provided in your terminal.

# API URL
SUPABASE_PUBLIC_URL=http://127.0.0.1:54321

# Anon Key (Public)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1...

# Database URL
# Format: postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# (Optional) Local Site URLs for redirect testing
SITE_URL=http://localhost:8501
RESET_URL=http://localhost:8501/reset_password
